# =============================================================================
# CRIBFLOW BACKEND ENVIRONMENT
# Copy this file to .env and fill in your values.
# =============================================================================

# ---- Server ----
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
# Secret bearer token protecting admin endpoints (/api/mpesa/register-urls, /simulate).
# Generate a long random value; required for those endpoints to work at all.
ADMIN_TOKEN=
# Secret protecting scheduled-job endpoints (/api/jobs/*), sent by DirectAdmin
# cron as the  X-Cron-Token  header. Generate a long random value.
CRON_TOKEN=

# ---- Supabase (service role — backend only, NEVER share publicly) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- M-Pesa Daraja API ----
# Sandbox: developer.safaricom.co.ke (free, for testing)
# Production: requires registered Paybill + Daraja go-live approval
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# These URLs MUST be publicly reachable (use ngrok for local dev)
MPESA_VALIDATION_URL=https://crib-api.flows.co.ke/api/c2b/validation
MPESA_CONFIRMATION_URL=https://crib-api.flows.co.ke/api/c2b/confirmation
# Optional: comma-separated Safaricom IPs allowed to hit the callback endpoints.
# Leave empty to allow all (recommended to fill in with Safaricom's IPs for prod).
MPESA_ALLOWED_IPS=

# ---- Email ----
# Option B (recommended): your own domain mailbox via SMTP (e.g. DirectAdmin).
# If SMTP_HOST is set it is used; otherwise it falls back to Gmail below.
SMTP_HOST=mail.flows.co.ke
SMTP_PORT=465
SMTP_SECURE=true                 # true for port 465, false for 587 (STARTTLS)
SMTP_USER=noreply@flows.co.ke
SMTP_PASS=
EMAIL_FROM=noreply@flows.co.ke   # the visible From address
EMAIL_FROM_NAME=CribFlow

# Option A (fallback): Gmail App Password (only used if SMTP_HOST is empty)
# https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=
