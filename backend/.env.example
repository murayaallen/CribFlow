# =============================================================================
# CRIBFLOW BACKEND ENVIRONMENT
# Copy this file to .env and fill in your values.
# =============================================================================

# ---- Server ----
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# ---- Supabase (service role — backend only, NEVER share publicly) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- M-Pesa Daraja API ----
# Sandbox: developer.safaricom.co.ke (free, for testing)
# Production: requires registered Paybill + Daraja go-live approval
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# These URLs MUST be publicly reachable (use ngrok for local dev)
MPESA_VALIDATION_URL=https://yourdomain.com/api/mpesa/validation
MPESA_CONFIRMATION_URL=https://yourdomain.com/api/mpesa/confirmation

# ---- Email (Gmail SMTP) ----
# Use a Gmail App Password, not your account password
# https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM_NAME=CribFlow
